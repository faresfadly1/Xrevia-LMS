
<odoo>
    <record id="view_lms_course_tree" model="ir.ui.view">
        <field name="name">lms.course.tree</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="enrolled_count"/>
            </list>
        </field>
    </record>

    <record id="view_lms_course_form" model="ir.ui.view">
        <field name="name">lms.course.form</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="teacher_id"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Lessons">
                            <field name="lesson_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="video_url"/>
                                </list>
                            </field>
                        </page>
                        <page string="Announcements">
                            <field name="announcement_ids">
                                <list editable="bottom">
                                    <field name="title"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Quizzes">
                            <field name="quiz_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="total_questions"/>
                                </list>
                            </field>
                        </page>
                        <page string="Enrollments">
                            <field name="enrollment_ids">
                                <list editable="bottom">
                                    <field name="student_id"/>
                                    <field name="status"/>
                                    <field name="progress"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">lms.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lms_root" name="LMS" sequence="10" action="action_lms_course" web_icon="my_custom_lms,static/description/icon.png"/>
    <menuitem id="menu_lms_courses" name="Courses" parent="menu_lms_root" action="action_lms_course" sequence="10"/>
</odoo>
