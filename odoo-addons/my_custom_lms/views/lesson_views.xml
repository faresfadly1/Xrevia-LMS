<odoo>
    <record id="view_lms_lesson_tree" model="ir.ui.view">
        <field name="name">lms.lesson.tree</field>
        <field name="model">lms.lesson</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="course_id"/>
                <field name="video_url"/>
            </list>
        </field>
    </record>

    <record id="view_lms_lesson_form" model="ir.ui.view">
        <field name="name">lms.lesson.form</field>
        <field name="model">lms.lesson</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="course_id"/>
                        <field name="sequence"/>
                    </group>
                    <group>
                        <field name="video_url"/>
                        <field name="file" filename="file_filename"/>
                        <field name="file_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="content" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_lesson" model="ir.actions.act_window">
        <field name="name">Lessons</field>
        <field name="res_model">lms.lesson</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lms_lessons" name="Lessons" parent="menu_lms_root" action="action_lms_lesson" sequence="20"/>
</odoo>
