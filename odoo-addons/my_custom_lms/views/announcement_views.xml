<odoo>
    <record id="view_lms_announcement_tree" model="ir.ui.view">
        <field name="name">lms.announcement.tree</field>
        <field name="model">lms.announcement</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="course_id"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <record id="view_lms_announcement_form" model="ir.ui.view">
        <field name="name">lms.announcement.form</field>
        <field name="model">lms.announcement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="course_id"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">lms.announcement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lms_announcements" name="Announcements" parent="menu_lms_root" action="action_lms_announcement" sequence="30"/>
</odoo>
