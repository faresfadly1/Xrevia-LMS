<odoo>
    <record id="module_category_lms" model="ir.module.category">
        <field name="name">LMS</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_lms_teacher" model="res.groups">
        <field name="name">LMS Teacher</field>
        <field name="category_id" ref="my_custom_lms.module_category_lms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_partner_manager'))]"/>
    </record>

    <record id="group_lms_admin" model="res.groups">
        <field name="name">LMS Admin</field>
        <field name="category_id" ref="my_custom_lms.module_category_lms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_system')), (4, ref('base.group_partner_manager')), (4, ref('base.group_allow_export'))]"/>
    </record>

    <record id="group_lms_student" model="res.groups">
        <field name="name">LMS Student</field>
        <field name="category_id" ref="my_custom_lms.module_category_lms"/>
    </record>
</odoo>
