<odoo>
    <!-- Teacher access limited to their own courses and related records -->
    <record id="rule_lms_teacher_course" model="ir.rule">
        <field name="name">LMS Teacher: Own Courses</field>
        <field name="model_id" ref="model_lms_course"/>
        <field name="groups" eval="[(4, ref('my_custom_lms.group_lms_teacher'))]"/>
        <field name="domain_force">[('teacher_id', '=', user.id)]</field>
    </record>
    <record id="rule_lms_teacher_lesson" model="ir.rule">
        <field name="name">LMS Teacher: Own Lessons</field>
        <field name="model_id" ref="model_lms_lesson"/>
        <field name="groups" eval="[(4, ref('my_custom_lms.group_lms_teacher'))]"/>
        <field name="domain_force">[('course_id.teacher_id', '=', user.id)]</field>
    </record>
