        <field name="domain_force">[('quiz_id.course_id.teacher_id', '=', user.id)]</field>
    </record>
    <record id="rule_lms_teacher_result" model="ir.rule">
        <field name="name">LMS Teacher: Own Results</field>
        <field name="model_id" ref="model_lms_quiz_result"/>
