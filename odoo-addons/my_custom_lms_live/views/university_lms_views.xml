<odoo>
    <record id="view_lms_course_tree_university_live" model="ir.ui.view">
        <field name="name">lms.course.tree.university.live</field>
        <field name="model">lms.course</field>
        <field name="inherit_id" ref="my_custom_lms.view_lms_course_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='name']" position="after">
                <field name="x_course_code"/>
                <field name="x_department"/>
                <field name="x_term"/>
                <field name="x_status"/>
                <field name="x_is_published"/>
            </xpath>
        </field>
    </record>

    <record id="view_lms_course_form_university_live" model="ir.ui.view">
        <field name="name">lms.course.form.university.live</field>
        <field name="model">lms.course</field>
        <field name="inherit_id" ref="my_custom_lms.view_lms_course_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='teacher_id']]" position="replace">
                <group>
                    <field name="teacher_id"/>
                    <field name="x_course_code"/>
                    <field name="x_department"/>
                    <field name="x_term"/>
                    <field name="x_status"/>
                    <field name="x_is_published"/>
                    <field name="x_auto_enroll"/>
                    <field name="x_cover_image" widget="image" class="oe_avatar"/>
                    <field name="description"/>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Assignments">
                    <field name="assignment_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="due_date"/>
                            <field name="max_score"/>
                            <field name="submission_count" readonly="1"/>
                            <field name="pending_count" readonly="1"/>
                            <field name="is_published"/>
                        </list>
                    </field>
                </page>
                <page string="Attendance">
                    <field name="attendance_session_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="lesson_id"/>
                            <field name="session_date"/>
                            <field name="present_count" readonly="1"/>
                            <field name="late_count" readonly="1"/>
                            <field name="absent_count" readonly="1"/>
                            <field name="status"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_lms_lesson_form_university_live" model="ir.ui.view">
        <field name="name">lms.lesson.form.university.live</field>
        <field name="model">lms.lesson</field>
        <field name="inherit_id" ref="my_custom_lms.view_lms_lesson_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='name']]" position="inside">
                <field name="x_module_title"/>
                <field name="x_week_label"/>
                <field name="x_topic_title"/>
                <field name="x_unit_title"/>
            </xpath>
            <xpath expr="//group[field[@name='video_url']]" position="inside">
                <field name="x_external_resource_url"/>
            </xpath>
        </field>
    </record>

    <record id="view_lms_quiz_form_university_live" model="ir.ui.view">
        <field name="name">lms.quiz.form.university.live</field>
        <field name="model">lms.quiz</field>
        <field name="inherit_id" ref="my_custom_lms.view_lms_quiz_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[field[@name='name']]" position="inside">
                <field name="x_available_from"/>
                <field name="x_deadline"/>
                <field name="x_time_limit_minutes"/>
                <field name="x_attempt_limit"/>
                <field name="x_pass_percentage"/>
                <field name="x_weight"/>
                <field name="x_show_results"/>
            </xpath>
        </field>
    </record>

    <record id="view_lms_assignment_tree_live" model="ir.ui.view">
        <field name="name">lms.assignment.tree.live</field>
        <field name="model">lms.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="course_id"/>
                <field name="due_date"/>
                <field name="max_score"/>
                <field name="submission_count"/>
                <field name="pending_count"/>
                <field name="average_percentage"/>
                <field name="is_published"/>
            </list>
        </field>
    </record>

    <record id="view_lms_assignment_form_live" model="ir.ui.view">
        <field name="name">lms.assignment.form.live</field>
        <field name="model">lms.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="course_id"/>
                        <field name="teacher_id" readonly="1"/>
                        <field name="due_date"/>
                        <field name="available_from"/>
                        <field name="submission_type"/>
                        <field name="max_score"/>
                        <field name="weight"/>
                        <field name="allow_late"/>
                        <field name="allow_resubmission"/>
                        <field name="is_published"/>
                    </group>
                    <group>
                        <field name="resource_file" filename="resource_filename"/>
                        <field name="resource_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="description" widget="html"/>
                        <field name="instructions" widget="html"/>
                    </group>
                    <group>
                        <field name="submission_ids">
                            <list>
                                <field name="student_id"/>
                                <field name="status"/>
                                <field name="submitted_on"/>
                                <field name="score"/>
                                <field name="percentage"/>
                                <field name="graded_on"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_assignment_live" model="ir.actions.act_window">
        <field name="name">Assignments</field>
        <field name="res_model">lms.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_lms_assignment_submission_tree_live" model="ir.ui.view">
        <field name="name">lms.assignment.submission.tree.live</field>
        <field name="model">lms.assignment.submission</field>
        <field name="arch" type="xml">
            <list>
                <field name="assignment_id"/>
                <field name="student_id"/>
                <field name="status"/>
                <field name="submitted_on"/>
                <field name="score"/>
                <field name="percentage"/>
                <field name="graded_on"/>
            </list>
        </field>
    </record>

    <record id="view_lms_assignment_submission_form_live" model="ir.ui.view">
        <field name="name">lms.assignment.submission.form.live</field>
        <field name="model">lms.assignment.submission</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="assignment_id"/>
                        <field name="student_id"/>
                        <field name="status"/>
                        <field name="submitted_on"/>
                        <field name="graded_on"/>
                        <field name="score"/>
                        <field name="percentage"/>
                    </group>
                    <group>
                        <field name="submitted_file" filename="submitted_filename"/>
                        <field name="submitted_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="submission_text" widget="html"/>
                        <field name="feedback" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_assignment_submission_live" model="ir.actions.act_window">
        <field name="name">Assignment Submissions</field>
        <field name="res_model">lms.assignment.submission</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_lms_attendance_session_tree_live" model="ir.ui.view">
        <field name="name">lms.attendance.session.tree.live</field>
        <field name="model">lms.attendance.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="course_id"/>
                <field name="lesson_id"/>
                <field name="session_date"/>
                <field name="present_count"/>
                <field name="late_count"/>
                <field name="absent_count"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_lms_attendance_session_form_live" model="ir.ui.view">
        <field name="name">lms.attendance.session.form.live</field>
        <field name="model">lms.attendance.session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="course_id"/>
                        <field name="lesson_id"/>
                        <field name="session_date"/>
                        <field name="status"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="record_ids">
                            <list editable="bottom">
                                <field name="student_id"/>
                                <field name="status"/>
                                <field name="note"/>
                                <field name="marked_on"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_attendance_session_live" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">lms.attendance.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lms_assignments_live" name="Assignments" parent="my_custom_lms.menu_lms_root" action="action_lms_assignment_live" sequence="45"/>
    <menuitem id="menu_lms_assignment_submissions_live" name="Assignment Submissions" parent="my_custom_lms.menu_lms_root" action="action_lms_assignment_submission_live" sequence="46"/>
    <menuitem id="menu_lms_attendance_live" name="Attendance" parent="my_custom_lms.menu_lms_root" action="action_lms_attendance_session_live" sequence="47"/>
</odoo>
