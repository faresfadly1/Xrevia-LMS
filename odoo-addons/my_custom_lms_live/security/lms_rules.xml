<odoo>
    <record id="rule_lms_course_portal_live" model="ir.rule">
        <field name="name">Portal published LMS courses</field>
        <field name="model_id" ref="my_custom_lms.model_lms_course"/>
        <field name="groups" eval="[(4, ref('base.group_portal')), (4, ref('my_custom_lms.group_lms_student'))]"/>
        <field name="domain_force">[('x_is_published', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

